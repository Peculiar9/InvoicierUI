# API Configuration. Relative by default so the deployed build calls its own
# origin (/api), which the mock backend intercepts. Set to an absolute backend
# URL only when VITE_USE_MOCKS=false.
VITE_API_URL=/api

# Use the in-app mock backend (localStorage-backed), in dev AND production.
# Set to "false" to hit a real VITE_API_URL instead.
VITE_USE_MOCKS=true

# EmailJS (optional) — when all three are set, "Send" emails invoices for real
# via the EmailJS REST API. Without them, Send opens the user's mail composer (mailto:).
# Get these from https://emailjs.com -> Email Services / Templates / Account (Public Key).
# Your EmailJS template should use the params: to_email, to_name, from_name, subject, message
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
